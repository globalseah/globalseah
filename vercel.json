{
  "functions": {
    "api/contact.js": {
      "maxDuration": 10
    },
    "api/admin/posts.js": {
      "maxDuration": 10
    },
    "api/admin/upload.js": {
      "maxDuration": 10
    },
    "api/posts.js": {
      "maxDuration": 10
    },
    "api/ga4-id.js": {
      "maxDuration": 10
    },
    "api/admin/analytics.js": {
      "maxDuration": 15
    }
  },
  "redirects": [
    { "source": "/admin", "destination": "/admin/", "permanent": false }
  ],
  "headers": [
    {
      "source": "/admin/admin.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/admin/notices", "destination": "/admin/notices.html" },
    { "source": "/admin/portfolio", "destination": "/admin/portfolio.html" },
    { "source": "/admin/recruit", "destination": "/admin/recruit.html" },
    { "source": "/admin/stats", "destination": "/admin/stats.html" }
  ]
}
