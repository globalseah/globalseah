# Resend (https://resend.com) API 키
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# 문의 수신 이메일 (테스트: dawoon4209@gmail.com / 운영: seah0905@naver.com)
CONTACT_TO_EMAIL=dawoon4209@gmail.com

# 발신 주소 — Resend Domains 인증 후 예: 글로벌세아 <contact@구매한도메인>
CONTACT_FROM_EMAIL=글로벌세아 <contact@구매한도메인>

# --- Phase 0: Supabase (dev / prod 각각 다른 값) ---
# Supabase → Project Settings → API
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ⚠ service role — 서버 전용, Git 커밋·클라이언트 노출 금지
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Phase 2: Basic Auth (Preview 테스트용 + 운영 배포 전 최종값 설정) ---
ADMIN_USER=admin
ADMIN_PASS=change-me-before-deploy

# --- Phase 7: GA4 ---
# 측정 ID (공개 사이트 gtag + /api/ga4-id)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# 속성 ID (숫자만) — GA4 관리 → 속성 설정 → 속성 ID
GA4_PROPERTY_ID=123456789
# Google Cloud 서비스 계정 (Analytics Data API)
GA4_CLIENT_EMAIL=analytics@your-project.iam.gserviceaccount.com
# JSON 키의 private_key — Vercel에는 \n 포함 한 줄 문자열로 입력
GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
